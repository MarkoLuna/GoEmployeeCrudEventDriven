{
  "version": "1.0",
  "project": {
    "name": "GoEmployeeCrudEventDriven",
    "description": "Employee CRUD REST API with Event-Driven Architecture using Go and Apache Kafka"
  },
  "ignore": [
    "**/*.sum",
    "**/vendor/**",
    "**/.env",
    "**/ssl/*.pem",
    "**/docs/swagger.json",
    "**/docs/swagger.yaml",
    "**/docs/docs.go"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate.sh"
          }
        ]
      }
    ]
  }
}
