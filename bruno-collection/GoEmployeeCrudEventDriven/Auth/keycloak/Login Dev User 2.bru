meta {
  name: Login Dev User 2
  type: http
  seq: 1
}

post {
  url: http://localhost:8082/realms/dev/protocol/openid-connect/token
  body: formUrlEncoded
  auth: inherit
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  client_id: newClient
  client_secret: newClientSecret
  username: mike@other.com
  password: pass
  grant_type: password
}

script:post-response {
  var jsonData = res.getBody();
  if (jsonData["access_token"] != null) {
      bru.setEnvVar("auth_token", jsonData["access_token"]);
  }
  if (jsonData["token_type"] != null) {
      bru.setEnvVar("auth_type", jsonData["token_type"]);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}
