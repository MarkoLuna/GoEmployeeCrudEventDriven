# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
OAUTH_ENABLED=true
SERVER_SSL_ENABLED=false

# Auth Service
AUTH_SERVICE_URL=http://localhost:8082

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=employee-group

# Kafka Producer Topics
KAFKA_PRODUCER_EMPLOYEE_INSERT_TOPIC=employee-insert.v1
KAFKA_PRODUCER_EMPLOYEE_UPDATE_TOPIC=employee-update.v1
KAFKA_PRODUCER_EMPLOYEE_DELETE_TOPIC=employee-deletion.v1

# Kafka Consumer Topics
KAFKA_CONSUMER_EMPLOYEE_INSERT_TOPIC=employee-insert.v1
KAFKA_CONSUMER_EMPLOYEE_UPDATE_TOPIC=employee-update.v1
KAFKA_CONSUMER_EMPLOYEE_DELETE_TOPIC=employee-deletion.v1

# Kafka DLT Topics
KAFKA_CONSUMER_EMPLOYEE_INSERT_DLT=employee-insert.v1.dlt
KAFKA_CONSUMER_EMPLOYEE_UPDATE_DLT=employee-update.v1.dlt
KAFKA_CONSUMER_EMPLOYEE_DELETE_DLT=employee-deletion.v1.dlt

# Service Discovery
EMPLOYEE_CONSUMER_HOST=http://localhost:8081
